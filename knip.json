{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/app/**/*.{ts,tsx}", "scripts/**/*.ts"],
  "project": ["src/**/*.{ts,tsx}", "scripts/**/*.ts"],
  "ignore": [
    "src/__tests__/**",
    "**/*.test.{ts,tsx}",
    "**/*.spec.{ts,tsx}"
  ],
  "ignoreDependencies": [],
  "ignoreExportsUsedInFile": true
}
